# Project-specific data — large files excluded, small committed artefacts kept
data/*.duckdb
data/*.parquet
!data/predictions.parquet
!data/panel_snapshot.parquet
data/*.csv
!data/fold_coefs.csv
!data/.gitkeep
# Robustness artefacts (small CSV/JSON) are committed so the cloud app can load them.
!data/robustness/
predictions/

# Generated figures: keep the publication PNGs for the README, ignore anything else.
figures/*
!figures/*.png

# Streamlit
